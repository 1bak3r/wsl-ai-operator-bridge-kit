+    chromeGoogleAccount: null,
+    registryEntries: [],
+    staleRegistryEntries: [],
+    legacyRegistryEntries: [],
+    managedRegistryEntry: null,
+    prunedRegistryEntries: 0,
+    prunedRegistryEntryReasons: {},
+    warnings: [],
+    operationDispatcherKey: 'managed-profile:/tmp/managed/default/chatgpt::service:chatgpt',
+    ...overrides,
+  };
+}
+
+function createIdentityReconciliation(
+  overrides: Partial<BrowserDoctorIdentityReconciliation> = {},
+): BrowserDoctorIdentityReconciliation {
+  return {
+    target: 'chatgpt',
+    authority: 'provider-app-session',
+    ok: false,
+    status: 'provider_app_identity_unavailable',
+    expectedIdentity: {
+      email: 'expected@example.test',
