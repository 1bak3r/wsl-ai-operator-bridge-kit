+#!/usr/bin/env tsx
+import fs from 'node:fs/promises';
+import os from 'node:os';
+import path from 'node:path';
+import { fileURLToPath } from 'node:url';
+import { Client } from '@modelcontextprotocol/sdk/client/index.js';
+import { StdioClientTransport } from '@modelcontextprotocol/sdk/client/stdio.js';
+import { setAuracallHomeDirOverrideForTest } from '../src/auracallHome.js';
+import { createExecutionRuntimeControl } from '../src/runtime/control.js';
+import {
+  createExecutionRun,
+  createExecutionRunEvent,
+  createExecutionRunRecordBundle,
+  createExecutionRunSharedState,
+  createExecutionRunStep,
+} from '../src/runtime/model.js';
+import type { ExecutionRunRecordBundle } from '../src/runtime/types.js';
+import { createTeamRunLocalActionRequest } from '../src/teams/model.js';
+import { DEFAULT_TEAM_RUN_EXECUTION_POLICY } from '../src/teams/types.js';
+
+interface Options {
+  keepHome: boolean;
+  mcpBin: string;
+  mode: LocalActionSmokeMode;
+}
+
+type LocalActionSmokeMode = 'node' | 'windows-powershell-bridge';
+
+const RUN_ID = 'run_mcp_local_action_smoke';
+const EXPECTED_STDOUT = 'AURACALL_LOCAL_ACTION_OK';
+const EXPECTED_POWERSHELL_STDOUT = 'AURACALL_WINDOWS_POWERSHELL_OK';
+const SCRIPT_DIR = path.dirname(fileURLToPath(import.meta.url));
+const REPO_ROOT = path.resolve(SCRIPT_DIR, '..');
+const WSL_POWERSHELL_BRIDGE_SCRIPT = path.join(REPO_ROOT, 'scripts', 'wsl-powershell-chat.sh');
+const WINDOWS_POWERSHELL_EXE = '/mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe';
+
+function expandHome(input: string): string {
+  if (input === '~') return os.homedir();
+  if (input.startsWith('~/')) return path.join(os.homedir(), input.slice(2));
+  return input;
+}
+
+function resolveMcpCommand(input: string): string {
+  const expanded = expandHome(input);
+  if (path.isAbsolute(expanded)) return expanded;
+  return /[\\/]/.test(expanded) ? path.resolve(process.cwd(), expanded) : expanded;
+}
+
+function parseArgs(argv: string[]): Options {
+  const options: Options = {
+    keepHome: false,
+    mcpBin: path.join(os.homedir(), '.local', 'bin', 'auracall-mcp'),
+    mode: 'node',
+  };
+  for (let index = 0; index < argv.length; index += 1) {
+    const arg = argv[index];
+    if (arg === '--') continue;
+    if (arg === '--mcp-bin') {
+      const value = argv[index + 1];
+      if (!value) throw new Error('--mcp-bin requires a path.');
+      options.mcpBin = resolveMcpCommand(value);
+      index += 1;
+      continue;
+    }
+    if (arg === '--keep-home') {
+      options.keepHome = true;
+      continue;
+    }
+    if (arg === '--windows-powershell-bridge') {
+      options.mode = 'windows-powershell-bridge';
+      continue;
+    }
+    if (arg === '--help' || arg === '-h') {
+      printHelp();
+      process.exit(0);
+    }
+    throw new Error(`Unknown option: ${arg}`);
+  }
+  return options;
+}
+
+function printHelp(): void {
+  console.log(`Smoke a planned bounded local action through one MCP stdio process.
+
+Usage:
+  pnpm tsx scripts/smoke-mcp-local-action.ts [options]
+
+Options:
+  --mcp-bin <path>              AuraCall MCP binary. Default: ~/.local/bin/auracall-mcp
+  --windows-powershell-bridge   Execute the WSL-to-Windows PowerShell bridge script
+  --keep-home                   Keep the temporary AURACALL_HOME_DIR for inspection
+  -h, --help                    Show this help
+`);
+}
+
+async function writeFixtureConfig(homeDir: string, mode: LocalActionSmokeMode): Promise<string> {
+  const configPath = path.join(homeDir, 'config.json');
+  const allowedCommands =
+    mode === 'windows-powershell-bridge'
+      ? [WSL_POWERSHELL_BRIDGE_SCRIPT]
+      : ['node'];
+  await fs.writeFile(
+    configPath,
+    `${JSON.stringify(
+      {
+        version: 2,
+        model: 'gpt-5.2',
+        engine: 'api',
+        auracallProfile: 'default',
+        runtime: {
+          localActions: {
+            shell: {
+              complexityStage: 'bounded-command',
+              allowedCommands,
+              allowedCwdRoots: [homeDir],
+              defaultShellActionTimeoutMs: 10_000,
+              maxShellActionTimeoutMs: 30_000,
+              maxCaptureChars: 4_000,
+            },
+          },
+        },
+      },
+      null,
+      2,
+    )}\n`,
+    'utf8',
+  );
+  return configPath;
+}
+
+async function seedPlannedLocalActionRun(homeDir: string, mode: LocalActionSmokeMode): Promise<void> {
+  setAuracallHomeDirOverrideForTest(homeDir);
+  const control = createExecutionRuntimeControl();
+  await control.createRun(createPlannedLocalActionBundle(homeDir, mode, new Date().toISOString()));
+}
+
+function createPlannedLocalActionBundle(
+  homeDir: string,
+  mode: LocalActionSmokeMode,
+  createdAt: string,
+): ExecutionRunRecordBundle {
+  const stepId = `${RUN_ID}:step:1`;
+  const plannedAction = createPlannedLocalAction(mode, homeDir, createdAt, stepId);
+  const events = [
+    createExecutionRunEvent({
+      id: `${RUN_ID}:event:run-created`,
+      runId: RUN_ID,
+      type: 'run-created',
+      createdAt,
+      note: 'created by MCP local-action smoke',
+    }),
+    createExecutionRunEvent({
+      id: `${RUN_ID}:event:${stepId}:runnable`,
+      runId: RUN_ID,
+      stepId,
+      type: 'step-runnable',
+      createdAt,
+      note: 'planned local-action smoke step is runnable',
+      payload: {
+        order: 1,
+      },
+    }),
+  ];
+
+  return createExecutionRunRecordBundle({
+    run: createExecutionRun({
+      id: RUN_ID,
+      sourceKind: 'direct',
+      sourceId: null,
+      status: 'planned',
+      createdAt,
+      updatedAt: createdAt,
+      trigger: 'mcp',
+      requestedBy: 'smoke-mcp-local-action',
+      entryPrompt: 'Execute one bounded local host action.',
+      initialInputs: {
+        model: 'gpt-5.2',
+        runtimeProfile: 'default',
+        service: 'chatgpt',
+      },
+      sharedStateId: `${RUN_ID}:state`,
+      stepIds: [stepId],
+      policy: DEFAULT_TEAM_RUN_EXECUTION_POLICY,
+    }),
+    steps: [
+      createExecutionRunStep({
+        id: stepId,
+        runId: RUN_ID,
+        agentId: 'api-responses',
+        runtimeProfileId: 'default',
+        browserProfileId: null,
+        service: 'chatgpt',
+        kind: 'prompt',
+        status: 'runnable',
+        order: 1,
+        dependsOnStepIds: [],
+        input: {
+          prompt: 'Execute the planned local-action smoke.',
+          handoffIds: [],
+          artifacts: [],
+          structuredData: {
+            localActionPolicy: {
+              mode: 'allowed',
+              allowedActionKinds: ['shell'],
+              allowedCommands: [plannedAction.command],
+              allowedCwdRoots: [homeDir],
+            },
+          },
+          notes: ['This smoke proves the host-action path without contacting a provider.'],
+        },
+      }),
+    ],
+    localActionRequests: [plannedAction],
+    sharedState: createExecutionRunSharedState({
+      id: `${RUN_ID}:state`,
+      runId: RUN_ID,
+      status: 'active',
+      artifacts: [],
+      structuredOutputs: [],
+      notes: [],
+      history: events,
+      lastUpdatedAt: createdAt,
+    }),
+    events,
+  });
+}
+
+function createPlannedLocalAction(
+  mode: LocalActionSmokeMode,
+  homeDir: string,
+  createdAt: string,
+  stepId: string,
+) {
+  if (mode === 'windows-powershell-bridge') {
+    return createTeamRunLocalActionRequest({
+      id: `${RUN_ID}:action:${stepId}:bundle:1`,
+      teamRunId: RUN_ID,
+      ownerStepId: stepId,
+      kind: 'shell',
+      summary: 'Run the WSL-to-Windows PowerShell bridge from the host runtime.',
+      command: WSL_POWERSHELL_BRIDGE_SCRIPT,
+      args: [`Write-Output ${quotePowerShellString(EXPECTED_POWERSHELL_STDOUT)}`],
+      structuredPayload: {
+        cwd: homeDir,
+        timeoutMs: 20_000,
+      },
+      createdAt,
+    });
+  }
+
+  return createTeamRunLocalActionRequest({
+    id: `${RUN_ID}:action:${stepId}:bundle:1`,
+    teamRunId: RUN_ID,
+    ownerStepId: stepId,
+    kind: 'shell',
+    summary: 'Run one bounded node command from the host runtime.',
+    command: 'node',
+    args: ['-e', `process.stdout.write(${JSON.stringify(EXPECTED_STDOUT)})`],
+    structuredPayload: {
+      cwd: homeDir,
+      timeoutMs: 10_000,
+    },
+    createdAt,
+  });
+}
+
+function quotePowerShellString(value: string): string {
+  return `'${value.replace(/'/g, "''")}'`;
+}
+
+async function callInstalledMcp(input: {
+  mcpBin: string;
+  cwd: string;
+  env: Record<string, string>;
+}): Promise<{
+  claimStatus: string;
+  drainStatus: string;
+  runStatus: string;
+}> {
+  const client = new Client({ name: 'auracall-local-action-mcp-smoke', version: '0.0.0' });
+  let stderr = '';
+  const transport = new StdioClientTransport({
+    command: input.mcpBin,
+    cwd: input.cwd,
+    env: input.env,
+    stderr: 'pipe',
+  });
+  transport.stderr?.on('data', (chunk) => {
+    stderr += String(chunk);
+  });
+
+  try {
+    await client.connect(transport);
+    const { tools } = await client.listTools({}, { timeout: 10_000 });
+    assertToolListed(tools, 'runtime_control');
+    assertToolListed(tools, 'run_status');
+
+    const claim = await client.callTool(
+      {
+        name: 'runtime_control',
+        arguments: {
+          action: 'claim-local-run',
+          runId: RUN_ID,
+          schedulerId: 'smoke:mcp-local-action',
+        },
+      },
+      undefined,
+      { timeout: 10_000 },
+    );
+    const claimStructured = asRecord(claim.structuredContent, 'claim structuredContent');
+    assertEqual(claim.isError, false, 'claim isError');
+    assertEqual(claimStructured.object, 'runtime_control', 'claim object');
+    assertEqual(claimStructured.ok, true, 'claim ok');
+    const claimResult = asRecord(claimStructured.result, 'claim result');
+    assertEqual(claimResult.status, 'claimed', 'claim status');
+
+    const drain = await client.callTool(
+      {
+        name: 'runtime_control',
+        arguments: {
+          action: 'drain-run',
+          runId: RUN_ID,
+        },
+      },
+      undefined,
+      { timeout: 15_000 },
+    );
+    const drainStructured = asRecord(drain.structuredContent, 'drain structuredContent');
+    assertEqual(drain.isError, false, 'drain isError');
+    assertEqual(drainStructured.object, 'runtime_control', 'drain object');
+    assertEqual(drainStructured.ok, true, 'drain ok');
+    const drainResult = asRecord(drainStructured.result, 'drain result');
+    assertEqual(drainResult.status, 'executed', 'drain status');
+
+    const status = await client.callTool(
+      {
+        name: 'run_status',
+        arguments: {
+          id: RUN_ID,
+        },
+      },
+      undefined,
+      { timeout: 10_000 },
+    );
+    const statusStructured = asRecord(status.structuredContent, 'run_status structuredContent');
+    assertEqual(status.isError, false, 'run_status isError');
+    assertEqual(statusStructured.object, 'auracall_run_status', 'run_status object');
+    assertEqual(statusStructured.id, RUN_ID, 'run_status id');
+    assertEqual(statusStructured.status, 'completed', 'run_status status');
+
+    return {
+      claimStatus: String(claimResult.status),
+      drainStatus: String(drainResult.status),
+      runStatus: String(statusStructured.status),
+    };
+  } finally {
+    await client.close().catch(() => {});
+    transport.close?.();
+    if (stderr.trim().length > 0 && process.env.AURACALL_SMOKE_DEBUG_STDERR === '1') {
+      console.error(stderr.trim());
+    }
+  }
+}
+
+async function assertStoredBundle(homeDir: string): Promise<{
+  actionStatus: string;
+  actionStdout: string;
+  leaseOwner: string;
+  leaseStatus: string;
+  powershellStdout: string | null;
+}> {
+  setAuracallHomeDirOverrideForTest(homeDir);
+  const control = createExecutionRuntimeControl();
+  const record = await control.readRun(RUN_ID);
+  if (!record) throw new Error(`Stored run ${RUN_ID} was not found.`);
+  assertEqual(record.bundle.run.status, 'succeeded', 'stored run status');
+  const step = record.bundle.steps[0];
+  if (!step) throw new Error('Stored run has no first step.');
+  assertEqual(step.status, 'succeeded', 'stored step status');
+  const request = record.bundle.localActionRequests[0];
+  if (!request) throw new Error('Stored run has no local action request.');
+  assertEqual(request.status, 'executed', 'local action status');
+  const resultPayload = asRecord(request.resultPayload, 'local action resultPayload');
+  assertEqual(resultPayload.exitCode, 0, 'local action exitCode');
+  const actionStdout = expectString(resultPayload.stdout, 'local action stdout');
+  const powershellStdout =
+    request.command === WSL_POWERSHELL_BRIDGE_SCRIPT
+      ? assertPowerShellBridgeStdout(actionStdout)
+      : null;
+  if (powershellStdout === null) {
+    assertEqual(actionStdout, EXPECTED_STDOUT, 'local action stdout');
+  }
+  const lease = record.bundle.leases.at(-1);
+  if (!lease) throw new Error('Stored run has no lease record.');
+  if (!lease.ownerId.startsWith('runner:mcp-runtime-control:')) {
+    throw new Error(`lease owner: expected runner:mcp-runtime-control:<pid>, got ${lease.ownerId}.`);
+  }
+  assertEqual(lease.status, 'released', 'lease status');
+  assertEqual(lease.releaseReason, 'completed', 'lease release reason');
+  return {
+    actionStatus: request.status,
+    actionStdout,
+    leaseOwner: lease.ownerId,
+    leaseStatus: lease.status,
+    powershellStdout,
+  };
+}
+
+function assertPowerShellBridgeStdout(stdout: string): string {
+  const records = stdout.split(/\r?\n/u).filter((line) => line.trim().length > 0).map((line) => {
+    try {
+      return JSON.parse(line) as Record<string, unknown>;
+    } catch {
+      throw new Error(`PowerShell bridge stdout line was not JSON: ${line}`);
+    }
+  });
+  const result = records.find((record) => record.type === 'result');
+  if (!result) {
+    throw new Error('PowerShell bridge stdout did not include a result record.');
+  }
+  assertEqual(result.ok, true, 'PowerShell bridge result ok');
+  const resultStdout = Array.isArray(result.stdout)
+    ? result.stdout.filter((value): value is string => typeof value === 'string')
+    : [];
+  if (!resultStdout.includes(EXPECTED_POWERSHELL_STDOUT)) {
+    throw new Error(`PowerShell bridge stdout did not include ${EXPECTED_POWERSHELL_STDOUT}.`);
+  }
+  return EXPECTED_POWERSHELL_STDOUT;
+}
+
+function assertToolListed(tools: Array<{ name?: string }>, toolName: string): void {
+  if (!tools.some((tool) => tool.name === toolName)) {
+    throw new Error(`Installed MCP server did not expose ${toolName}.`);
+  }
+}
+
+function assertEqual(actual: unknown, expected: unknown, label: string): void {
+  if (actual !== expected) {
+    throw new Error(`${label}: expected ${String(expected)}, got ${String(actual)}.`);
+  }
+}
+
+function asRecord(value: unknown, label: string): Record<string, unknown> {
+  if (!value || typeof value !== 'object' || Array.isArray(value)) {
+    throw new Error(`${label}: expected object, got ${String(value)}.`);
+  }
+  return value as Record<string, unknown>;
+}
+
+function expectString(value: unknown, label: string): string {
+  if (typeof value !== 'string') {
+    throw new Error(`${label}: expected string, got ${String(value)}.`);
+  }
+  return value;
+}
+
+function normalizeEnv(env: NodeJS.ProcessEnv): Record<string, string> {
+  return Object.fromEntries(
+    Object.entries(env).filter((entry): entry is [string, string] =>
+      typeof entry[1] === 'string'),
+  );
+}
+
+async function main(): Promise<void> {
+  const options = parseArgs(process.argv.slice(2));
+  const homeDir = await fs.mkdtemp(path.join(os.tmpdir(), 'auracall-mcp-local-action-smoke-'));
+  const priorCwd = process.cwd();
+  try {
+    const configPath = await writeFixtureConfig(homeDir, options.mode);
+    process.env.AURACALL_HOME_DIR = homeDir;
+    process.env.AURACALL_CONFIG_PATH = configPath;
+    process.chdir(homeDir);
+    await seedPlannedLocalActionRun(homeDir, options.mode);
+    const protocol = await callInstalledMcp({
+      mcpBin: options.mcpBin,
+      cwd: homeDir,
+      env: {
+        ...normalizeEnv(process.env),
+        // biome-ignore lint/style/useNamingConvention: environment variables stay upper snake case
+        AURACALL_DISABLE_KEYTAR: '1',
+        // biome-ignore lint/style/useNamingConvention: environment variables stay upper snake case
+        AURACALL_HOME_DIR: homeDir,
+        // biome-ignore lint/style/useNamingConvention: environment variables stay upper snake case
+        AURACALL_CONFIG_PATH: configPath,
+        // biome-ignore lint/style/useNamingConvention: environment variables stay upper snake case
+        AURACALL_SYSTEM_CONFIG_PATH: path.join(homeDir, 'missing-system-config.json'),
+        ...(options.mode === 'windows-powershell-bridge'
+          ? {
+              // biome-ignore lint/style/useNamingConvention: environment variables stay upper snake case
+              AURACALL_WINDOWS_POWERSHELL:
+                process.env.AURACALL_WINDOWS_POWERSHELL ?? WINDOWS_POWERSHELL_EXE,
+            }
+          : {}),
+      },
+    });
+    const stored = await assertStoredBundle(homeDir);
+    console.log([
+      'local-action MCP smoke: pass',
+      'tool=runtime_control',
+      'listed=ok',
+      `claim=${protocol.claimStatus}`,
+      `drain=${protocol.drainStatus}`,
+      `run_status=${protocol.runStatus}`,
+      `mode=${options.mode}`,
+      `localAction=${stored.actionStatus}`,
+      `stdout=${stored.actionStdout}`,
+      stored.powershellStdout === null ? null : `powershellStdout=${stored.powershellStdout}`,
+      `leaseOwner=${stored.leaseOwner}`,
+      `leaseStatus=${stored.leaseStatus}`,
+      `fixtureHome=${homeDir}`,
+    ].filter((line): line is string => line !== null).join('\n'));
+  } finally {
+    process.chdir(priorCwd);
+    setAuracallHomeDirOverrideForTest(null);
