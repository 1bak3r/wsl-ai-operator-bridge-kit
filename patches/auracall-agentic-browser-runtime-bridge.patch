+    id: metadata.id,
+    object: 'response' as const,
+    status: metadata.status,
+    model: metadata.model,
+    output: [
+      {
+        type: 'message' as const,
+        role: 'assistant' as const,
+        content: [
+          {
+            type: 'output_text' as const,
+            text: log,
+          },
+        ],
+      },
+    ],
+    metadata: {
+      source: 'session-store',
+      session: metadata,
+      ...(request ? { request } : {}),
+    },
+  };
+}
diff --git a/src/mcp/tools/runtimeControl.ts b/src/mcp/tools/runtimeControl.ts
new file mode 100644
index 00000000..bd061274
--- /dev/null
+++ b/src/mcp/tools/runtimeControl.ts
@@ -0,0 +1,182 @@
+import type { McpServer } from '@modelcontextprotocol/sdk/server/mcp.js';
+import { z } from 'zod';
+import {
+  createExecutionServiceHost,
+  type ExecutionServiceHost,
+  type ExecutionServiceHostOperatorControlInput,
+  type ExecutionServiceHostOperatorControlResult,
+} from '../../runtime/serviceHost.js';
+
+const runtimeControlInputShape = {
+  action: z.enum([
+    'resolve-local-action-request',
+    'drain-run',
+    'cancel-run',
+    'resume-human-escalation',
+    'repair-stale-heartbeat',
+    'claim-local-run',
+  ]),
+  runId: z.string().min(1),
+  requestId: z.string().min(1).optional(),
+  resolution: z.enum(['approved', 'rejected', 'cancelled']).optional(),
+  note: z.string().min(1).nullable().optional(),
+  guidance: z.record(z.string(), z.unknown()).nullable().optional(),
+  override: z
+    .object({
+      promptAppend: z.string().min(1).nullable().optional(),
+      structuredContext: z.record(z.string(), z.unknown()).nullable().optional(),
+    })
+    .nullable()
+    .optional(),
+  schedulerId: z.string().min(1).optional(),
+  force: z.boolean().optional(),
+} satisfies z.ZodRawShape;
+
+const runtimeControlOutputShape = {
+  object: z.literal('runtime_control'),
+  action: z.string(),
+  runId: z.string(),
+  ok: z.boolean(),
+  result: z.unknown(),
+} satisfies z.ZodRawShape;
+
+type RuntimeControlInput = z.infer<z.ZodObject<typeof runtimeControlInputShape>>;
+
+export interface RegisterRuntimeControlToolDeps {
+  serviceHost?: Pick<ExecutionServiceHost, 'controlOperatorAction'>;
+}
+
+export function registerRuntimeControlTool(
+  server: McpServer,
+  deps: RegisterRuntimeControlToolDeps = {},
+): void {
+  server.registerTool(
+    'runtime_control',
+    {
+      title: 'Control an Aura-Call runtime run',
+      description:
+        'Apply one bounded service-host operator control to an existing Aura-Call runtime run, such as resolving a pending local-action request or triggering a targeted drain. This delegates to the same service-host controls used by the local HTTP status API.',
+      inputSchema: runtimeControlInputShape,
+      outputSchema: runtimeControlOutputShape,
+    },
+    createRuntimeControlToolHandler(deps),
+  );
+}
+
+export function createRuntimeControlToolHandler(deps: RegisterRuntimeControlToolDeps = {}) {
+  const serviceHost = deps.serviceHost ?? createExecutionServiceHost({ ownerId: 'host:mcp-runtime-control' });
+  return async (input: unknown) => {
+    const payload = z.object(runtimeControlInputShape).parse(input);
+    const controlInput = createOperatorControlInput(payload);
+    const result = await serviceHost.controlOperatorAction(controlInput);
+    const ok = isSuccessfulServiceHostOperatorControlResult(result);
+    const structuredContent = {
+      object: 'runtime_control' as const,
+      action: payload.action,
+      runId: payload.runId,
+      ok,
+      result,
+    };
+    return {
+      isError: !ok,
+      content: [
+        {
+          type: 'text' as const,
+          text: ok
+            ? `Runtime control ${payload.action} applied to ${payload.runId}.`
+            : `Runtime control ${payload.action} did not apply to ${payload.runId}: ${readControlReason(result)}`,
+        },
+      ],
+      structuredContent,
+    };
+  };
+}
+
+function createOperatorControlInput(payload: RuntimeControlInput): ExecutionServiceHostOperatorControlInput {
+  if (payload.action === 'resolve-local-action-request') {
+    if (!payload.requestId) {
+      throw new Error('runtime_control resolve-local-action-request requires requestId.');
+    }
+    if (!payload.resolution) {
+      throw new Error('runtime_control resolve-local-action-request requires resolution.');
+    }
+    return {
+      kind: 'local-action-control',
+      action: 'resolve-request',
+      runId: payload.runId,
+      requestId: payload.requestId,
+      resolution: payload.resolution,
+      note: payload.note ?? null,
+    };
+  }
+  if (payload.action === 'repair-stale-heartbeat') {
+    return {
+      kind: 'lease-repair',
+      action: 'repair-stale-heartbeat',
+      runId: payload.runId,
+      force: payload.force ?? false,
+    };
+  }
+  if (payload.action === 'claim-local-run') {
+    return {
+      kind: 'scheduler-control',
+      control: {
+        action: 'claim-local-run',
+        runId: payload.runId,
+        schedulerId: payload.schedulerId ?? 'auracall-mcp runtime_control',
+      },
+    };
+  }
+  if (payload.action === 'resume-human-escalation') {
+    return {
+      kind: 'run-control',
+      control: {
+        action: 'resume-human-escalation',
+        runId: payload.runId,
+        note: payload.note ?? null,
+        guidance: payload.guidance ?? null,
+        override: payload.override ?? null,
+      },
+    };
+  }
+  if (payload.action === 'cancel-run') {
+    return {
+      kind: 'run-control',
+      control: {
+        action: 'cancel-run',
+        runId: payload.runId,
+        note: payload.note ?? null,
+      },
+    };
+  }
+  return {
+    kind: 'run-control',
+    control: {
+      action: 'drain-run',
+      runId: payload.runId,
+    },
+  };
+}
+
+function isSuccessfulServiceHostOperatorControlResult(
+  result: ExecutionServiceHostOperatorControlResult,
+): boolean {
+  if (result.kind === 'lease-repair') {
+    return result.status === 'repaired';
+  }
+  if (result.kind === 'local-action-control') {
+    return result.status === 'resolved';
+  }
+  if (result.kind === 'scheduler-control') {
+    return result.status === 'claimed' || result.status === 'reassigned';
+  }
+  return (
+    (result.action === 'cancel-run' && result.status === 'cancelled') ||
+    (result.action === 'resume-human-escalation' && result.status === 'resumed') ||
+    (result.action === 'drain-run' && result.status === 'executed')
+  );
+}
+
+function readControlReason(result: ExecutionServiceHostOperatorControlResult): string {
+  return typeof result.reason === 'string' && result.reason.length > 0 ? result.reason : 'no reason reported';
+}
