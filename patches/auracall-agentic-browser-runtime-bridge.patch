+    expect(collectBrowserFeatureRuntime).not.toHaveBeenCalled();
+    expect(result).toMatchObject({
+      isError: false,
+      structuredContent: {
+        object: 'browser_readiness',
+        target: 'chatgpt',
+        mode: 'local',
