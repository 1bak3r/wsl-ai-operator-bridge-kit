diff --git a/tests/browser-service/chromeIdentity.test.ts b/tests/browser-service/chromeIdentity.test.ts
new file mode 100644
index 00000000..2a40d178
--- /dev/null
+++ b/tests/browser-service/chromeIdentity.test.ts
@@ -0,0 +1,64 @@
+import { describe, expect, test } from "vitest";
+import {
+	assertChromeLaunchPath,
+	isChromeCompatibleDevToolsVersion,
+	isMicrosoftEdgePath,
+} from "../../packages/browser-service/src/chromeIdentity.js";
+
+function devToolsVersion(entries: Array<[string, string]>): Record<string, string> {
+	return Object.fromEntries(entries);
+}
+
+describe("chromeIdentity (package)", () => {
+	test("identifies Microsoft Edge executable paths", () => {
+		expect(isMicrosoftEdgePath("/mnt/c/Program Files/Microsoft/Edge/Application/msedge.exe")).toBe(
+			true,
+		);
+		expect(isMicrosoftEdgePath("/mnt/c/Program Files/Google/Chrome/Application/chrome.exe")).toBe(
+			false,
+		);
+	});
+
+	test("rejects Microsoft Edge launch paths for remote debugging", () => {
+		expect(() =>
+			assertChromeLaunchPath("/mnt/c/Program Files/Google/Chrome/Application/chrome.exe"),
+		).not.toThrow();
+		expect(() =>
+			assertChromeLaunchPath("/mnt/c/Program Files/Microsoft/Edge/Application/msedge.exe"),
+		).toThrow(/must use Google Chrome, not Microsoft Edge/i);
+	});
+
+	test("rejects Edge DevTools identity even when the product string looks Chrome-like", () => {
+		expect(
+			isChromeCompatibleDevToolsVersion(devToolsVersion([["Browser", "Chrome/146.0.0.0"]])),
+		).toBe(true);
+		expect(
+			isChromeCompatibleDevToolsVersion(devToolsVersion([["Browser", "Microsoft Edge/146.0.0.0"]])),
+		).toBe(false);
+		expect(
+			isChromeCompatibleDevToolsVersion(
+				devToolsVersion([
+					["Browser", "Chrome/146.0.0.0"],
+					[
+						"User-Agent",
+						"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 Chrome/146.0.0.0 Safari/537.36 Edg/146.0.0.0",
+					],
+				]),
+			),
+		).toBe(false);
+	});
+
+	test("rejects Edge DevTools identity without an Edge opt-in escape hatch", () => {
+		expect(
+			isChromeCompatibleDevToolsVersion(
+				devToolsVersion([
+					["Browser", "Chrome/146.0.0.0"],
+					[
+						"User-Agent",
+						"Mozilla/5.0 AppleWebKit/537.36 Chrome/146.0.0.0 Safari/537.36 Edg/146.0.0.0",
+					],
+				]),
+			),
+		).toBe(false);
+	});
+});
