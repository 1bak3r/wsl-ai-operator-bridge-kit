+async function saveBrowserToolsDoctorSnapshot(input: {
+  target: string;
+  basePath: string;
+  contract: unknown;
+  reason: string;
+}): Promise<string> {
+  const timestamp = new Date().toISOString().replace(/[:.]/g, '-');
+  const safeReason = input.reason.replace(/[^a-z0-9._-]+/gi, '-').replace(/^-+|-+$/g, '') || 'browser-tools';
+  const filename = `auracall-browser-tools-${input.target}-${safeReason}-${timestamp}.json`;
+  const snapshotPath = path.join(input.basePath, filename);
+  await fs.writeFile(
+    snapshotPath,
+    JSON.stringify({
+      contract: 'auracall.browser-tools-snapshot',
+      version: 1,
+      generatedAt: new Date().toISOString(),
+      target: input.target,
+      reason: input.reason,
+      browserTools: input.contract,
+    }, null, 2),
+    'utf8',
+  );
+  return snapshotPath;
+}
