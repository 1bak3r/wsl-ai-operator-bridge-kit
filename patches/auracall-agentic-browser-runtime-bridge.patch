+import { describe, expect, it, vi } from 'vitest';
+import { createWindowsPowerShellProbeToolHandler } from '../src/mcp/tools/windowsPowerShellProbe.js';
+
+describe('mcp windows_powershell_probe tool', () => {
+  it('runs a constrained probe through the injected PowerShell runner', async () => {
+    const runPowerShell = vi.fn(async (_script: string, _timeoutMs: number) => ({
+      stdout: JSON.stringify({
+        ok: true,
+        data: {
+          path: 'C:\\Windows',
+          computerName: 'DESKTOP-GDJCAFT',
+        },
+        error: null,
+      }),
+      stderr: '',
+    }));
+    const handler = createWindowsPowerShellProbeToolHandler({
+      isWsl: () => true,
+      runPowerShell,
+    });
+
+    const result = await handler({ probe: 'get_location' });
+
+    expect(runPowerShell).toHaveBeenCalledTimes(1);
+    expect(runPowerShell.mock.calls[0]?.[0]).toContain('Get-Location');
+    expect(result).toMatchObject({
+      isError: false,
+      content: [
+        {
+          type: 'text',
+          text: 'Windows PowerShell probe get_location completed.',
+        },
+      ],
+      structuredContent: {
+        object: 'windows_powershell_probe',
+        probe: 'get_location',
+        ok: true,
+        data: {
+          path: 'C:\\Windows',
+        },
+        error: null,
+      },
+    });
+  });
+
+  it('rejects use outside WSL before invoking PowerShell', async () => {
+    const runPowerShell = vi.fn(async (_script: string, _timeoutMs: number) => ({
+      stdout: '',
+      stderr: '',
+    }));
+    const handler = createWindowsPowerShellProbeToolHandler({
+      isWsl: () => false,
+      runPowerShell,
+    });
+
+    const result = await handler({ probe: 'get_location' });
+
+    expect(runPowerShell).not.toHaveBeenCalled();
+    expect(result).toMatchObject({
+      isError: true,
+      structuredContent: {
+        ok: false,
+        error: 'windows_powershell_probe is only supported from WSL.',
+      },
+    });
+  });
+
+  it('reports invalid PowerShell JSON output as a tool error', async () => {
+    const handler = createWindowsPowerShellProbeToolHandler({
+      isWsl: () => true,
+      runPowerShell: vi.fn(async () => ({
+        stdout: 'not-json',
+        stderr: '',
+      })),
+    });
+
+    const result = await handler({ probe: 'get_location' });
+
+    expect(result).toMatchObject({
+      isError: true,
+      structuredContent: {
+        ok: false,
+        error: 'PowerShell probe output was not valid JSON.',
+      },
+    });
+  });
+
+  it('rejects unsupported process-name characters', async () => {
+    const handler = createWindowsPowerShellProbeToolHandler({
+      isWsl: () => true,
+      runPowerShell: vi.fn(async () => ({
+        stdout: '',
+        stderr: '',
+      })),
+    });
+
+    await expect(
+      handler({ probe: 'get_process', processName: 'chrome.exe; Remove-Item C:\\' }),
+    ).rejects.toThrow('processName contains unsupported characters.');
+  });
+});
