new file mode 100644
index 00000000..0aee84fc
--- /dev/null
+++ b/src/mcp/tools/windowsPowerShellProbe.ts
@@ -0,0 +1,282 @@
+import { execFile } from 'node:child_process';
+import { promisify } from 'node:util';
+import type { McpServer } from '@modelcontextprotocol/sdk/server/mcp.js';
+import { z } from 'zod';
+import { isWslEnvironment } from '../../../packages/browser-service/src/platformPaths.js';
+import { resolveWindowsPowerShellPath } from '../../../packages/browser-service/src/windowsLoopbackRelay.js';
+
+const execFileAsync = promisify(execFile);
+
+const windowsPowerShellProbeNames = [
+  'get_location',
+  'get_process',
+  'tcp_listeners',
+  'devtools_version',
+] as const;
+
+const windowsPowerShellProbeInputShape = {
+  probe: z.enum(windowsPowerShellProbeNames),
+  pid: z.number().int().positive().nullable().optional(),
+  processName: z.string().min(1).max(80).nullable().optional(),
+  port: z.number().int().positive().max(65535).nullable().optional(),
+  limit: z.number().int().positive().max(100).nullable().optional(),
+  timeoutMs: z.number().int().positive().max(30_000).nullable().optional(),
+} satisfies z.ZodRawShape;
+
+const windowsPowerShellProbeOutputShape = {
+  object: z.literal('windows_powershell_probe'),
+  probe: z.enum(windowsPowerShellProbeNames),
+  ok: z.boolean(),
+  data: z.unknown().nullable(),
+  error: z.string().nullable(),
+  stderr: z.string().optional(),
+} satisfies z.ZodRawShape;
+
+type WindowsPowerShellProbeInput = z.infer<z.ZodObject<typeof windowsPowerShellProbeInputShape>>;
+
+export interface WindowsPowerShellProbeRunnerResult {
+  stdout: string;
+  stderr: string;
+}
+
+export interface RegisterWindowsPowerShellProbeToolDeps {
+  runPowerShell?: (script: string, timeoutMs: number) => Promise<WindowsPowerShellProbeRunnerResult>;
+  isWsl?: () => boolean;
+}
+
+export function registerWindowsPowerShellProbeTool(
+  server: McpServer,
+  deps: RegisterWindowsPowerShellProbeToolDeps = {},
+): void {
+  server.registerTool(
+    'windows_powershell_probe',
+    {
+      title: 'Probe Windows PowerShell from WSL',
+      description:
+        'Run a constrained read-oriented Windows PowerShell diagnostic from WSL for Aura-Call/Chrome/DevTools troubleshooting. This is not an arbitrary command executor.',
+      inputSchema: windowsPowerShellProbeInputShape,
+      outputSchema: windowsPowerShellProbeOutputShape,
+    },
+    createWindowsPowerShellProbeToolHandler(deps),
+  );
+}
+
+export function createWindowsPowerShellProbeToolHandler(
+  deps: RegisterWindowsPowerShellProbeToolDeps = {},
+) {
+  const runPowerShell = deps.runPowerShell ?? runWindowsPowerShellScript;
+  const isWsl = deps.isWsl ?? isWslEnvironment;
+  return async (input: unknown) => {
+    const textContent = (text: string) => [{ type: 'text' as const, text }];
+    const payload = z.object(windowsPowerShellProbeInputShape).parse(input);
+    if (!isWsl()) {
+      const structuredContent = {
+        object: 'windows_powershell_probe' as const,
+        probe: payload.probe,
+        ok: false,
+        data: null,
+        error: 'windows_powershell_probe is only supported from WSL.',
+      };
+      return {
+        isError: true,
+        content: textContent(structuredContent.error),
+        structuredContent,
+      };
+    }
+
+    const timeoutMs = payload.timeoutMs ?? 10_000;
+    const script = buildWindowsPowerShellProbeScript(payload);
+    let result: WindowsPowerShellProbeRunnerResult;
+    try {
+      result = await runPowerShell(script, timeoutMs);
+    } catch (error) {
+      const message = error instanceof Error ? error.message : String(error);
+      const structuredContent = {
+        object: 'windows_powershell_probe' as const,
+        probe: payload.probe,
+        ok: false,
+        data: null,
+        error: message,
+      };
+      return {
+        isError: true,
+        content: textContent(`Windows PowerShell probe ${payload.probe} failed: ${message}`),
+        structuredContent,
+      };
+    }
+
+    const parsed = parseProbeResult(result.stdout, payload.probe);
+    const structuredContent = {
+      object: 'windows_powershell_probe' as const,
+      probe: payload.probe,
+      ok: parsed.ok,
+      data: parsed.data,
+      error: parsed.error,
+      ...(result.stderr.trim() ? { stderr: result.stderr } : {}),
+    };
+    return {
+      isError: !structuredContent.ok,
+      content: textContent(
+        structuredContent.ok
+          ? `Windows PowerShell probe ${payload.probe} completed.`
+          : `Windows PowerShell probe ${payload.probe} failed: ${structuredContent.error ?? 'unknown error'}`,
+      ),
+      structuredContent,
+    };
+  };
+}
+
+async function runWindowsPowerShellScript(
+  script: string,
+  timeoutMs: number,
+): Promise<WindowsPowerShellProbeRunnerResult> {
+  const encoded = Buffer.from(script, 'utf16le').toString('base64');
+  const { stdout, stderr } = await execFileAsync(
+    resolveWindowsPowerShellPath(),
+    ['-NoProfile', '-NonInteractive', '-ExecutionPolicy', 'Bypass', '-EncodedCommand', encoded],
+    {
+      timeout: timeoutMs,
+      maxBuffer: 1024 * 1024,
+      windowsHide: true,
+    },
+  );
+  return {
+    stdout: String(stdout ?? ''),
+    stderr: String(stderr ?? ''),
+  };
+}
+
+function buildWindowsPowerShellProbeScript(input: WindowsPowerShellProbeInput): string {
+  const limit = input.limit ?? 20;
+  const processName = sanitizePowerShellComparableName(input.processName ?? null);
+  const pid = typeof input.pid === 'number' ? input.pid : null;
+  const port = typeof input.port === 'number' ? input.port : null;
+  const body = (() => {
+    switch (input.probe) {
+      case 'get_location':
+        return `
+$data = @{
+  path = (Get-Location).Path
+  computerName = $env:COMPUTERNAME
+  powershellVersion = "$($PSVersionTable.PSVersion)"
+}
+Write-ProbeResult -Ok $true -Data $data
+`;
+      case 'get_process':
+        return `
+$items = Get-CimInstance Win32_Process
+${pid ? `$items = $items | Where-Object { [int]$_.ProcessId -eq ${pid} }` : ''}
+${processName ? `$processName = ${quotePowerShellString(processName)}; $items = $items | Where-Object { $_.Name -eq $processName }` : ''}
+$data = @($items | Select-Object -First ${limit} | ForEach-Object {
+  @{
+    processId = [int]$_.ProcessId
+    name = "$($_.Name)"
+    commandLine = "$($_.CommandLine)"
+  }
+})
+Write-ProbeResult -Ok $true -Data $data
+`;
+      case 'tcp_listeners':
+        return `
+$items = Get-NetTCPConnection -State Listen -ErrorAction Stop
+${pid ? `$items = $items | Where-Object { [int]$_.OwningProcess -eq ${pid} }` : ''}
+${port ? `$items = $items | Where-Object { [int]$_.LocalPort -eq ${port} }` : ''}
+$data = @($items | Select-Object -First ${limit} | ForEach-Object {
+  @{
+    localAddress = "$($_.LocalAddress)"
+    localPort = [int]$_.LocalPort
+    owningProcess = [int]$_.OwningProcess
+    state = "$($_.State)"
+  }
+})
+Write-ProbeResult -Ok $true -Data $data
+`;
+      case 'devtools_version':
+        if (!port) {
+          return `
+Write-ProbeResult -Ok $false -ErrorMessage 'devtools_version requires port.'
+`;
+        }
+        return `
+$uri = 'http://127.0.0.1:${port}/json/version'
+$response = Invoke-WebRequest -UseBasicParsing $uri -TimeoutSec 3
+$version = $response.Content | ConvertFrom-Json
+$data = @{
+  statusCode = [int]$response.StatusCode
+  uri = $uri
+  browser = "$($version.Browser)"
+  protocolVersion = "$($version.'Protocol-Version')"
+  userAgent = "$($version.'User-Agent')"
+  webSocketDebuggerUrl = "$($version.webSocketDebuggerUrl)"
+}
+Write-ProbeResult -Ok $true -Data $data
+`;
+    }
+  })();
+
+  return `
+$ErrorActionPreference = 'Stop'
+$ProgressPreference = 'SilentlyContinue'
+function Write-ProbeResult {
+  param(
+    [Parameter(Mandatory = $true)] [bool] $Ok,
+    [object] $Data = $null,
+    [string] $ErrorMessage = $null
+  )
+  @{
+    ok = $Ok
+    data = $Data
+    error = $ErrorMessage
+  } | ConvertTo-Json -Compress -Depth 8
+}
+try {
+${body}
+} catch {
+  Write-ProbeResult -Ok $false -ErrorMessage $_.Exception.Message
+}
+`.trim();
+}
+
+function parseProbeResult(stdout: string, probe: WindowsPowerShellProbeInput['probe']): {
+  ok: boolean;
+  data: unknown;
+  error: string | null;
+} {
+  const line = stdout.trim().split(/\r?\n/u).filter(Boolean).at(-1);
+  if (!line) {
+    return {
+      ok: false,
+      data: null,
+      error: 'PowerShell probe produced no JSON output.',
+    };
+  }
+  try {
+    const parsed = JSON.parse(line) as { ok?: unknown; data?: unknown; error?: unknown };
+    return {
+      ok: parsed.ok === true,
+      data: parsed.data ?? null,
+      error: typeof parsed.error === 'string' && parsed.error.length > 0 ? parsed.error : null,
+    };
+  } catch {
+    return {
+      ok: false,
+      data: { probe, stdout },
+      error: 'PowerShell probe output was not valid JSON.',
+    };
+  }
+}
+
+function sanitizePowerShellComparableName(value: string | null): string | null {
+  if (!value) {
+    return null;
+  }
+  const trimmed = value.trim();
+  if (!/^[A-Za-z0-9_. -]{1,80}$/u.test(trimmed)) {
+    throw new Error('processName contains unsupported characters.');
+  }
+  return trimmed;
+}
+
+function quotePowerShellString(value: string): string {
+  return `'${value.replace(/'/g, "''")}'`;
+}
