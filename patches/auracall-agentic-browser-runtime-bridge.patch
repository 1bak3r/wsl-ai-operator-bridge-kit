+import { describe, expect, it } from 'vitest';
+import { createRuntimeControlToolHandler } from '../src/mcp/tools/runtimeControl.js';
+import type {
+  ExecutionServiceHostOperatorControlInput,
+  ExecutionServiceHostOperatorControlResult,
+} from '../src/runtime/serviceHost.js';
+
+describe('mcp runtime_control tool', () => {
+  it('resolves a requested local action through the service-host operator control seam', async () => {
+    const calls: ExecutionServiceHostOperatorControlInput[] = [];
+    const handler = createRuntimeControlToolHandler({
+      serviceHost: {
+        async controlOperatorAction(input) {
+          calls.push(input);
+          return {
+            kind: 'local-action-control',
+            action: 'resolve-local-action-request',
+            runId: 'run_tooling_1',
+            requestId: 'run_tooling_1:action:run_tooling_1:step:1:1',
+            resolution: 'approved',
+            status: 'resolved',
+            resolved: true,
+            reason: 'local action approved by service host operator control',
+            resolvedAt: '2026-06-06T21:00:00.000Z',
+            ownerStepId: 'run_tooling_1:step:1',
+          } satisfies ExecutionServiceHostOperatorControlResult;
+        },
+      },
+    });
+
+    const result = await handler({
+      action: 'resolve-local-action-request',
+      runId: 'run_tooling_1',
+      requestId: 'run_tooling_1:action:run_tooling_1:step:1:1',
+      resolution: 'approved',
+      note: 'operator approved deterministic local smoke',
+    });
+
+    expect(calls).toEqual([
+      {
+        kind: 'local-action-control',
+        action: 'resolve-request',
+        runId: 'run_tooling_1',
+        requestId: 'run_tooling_1:action:run_tooling_1:step:1:1',
+        resolution: 'approved',
+        note: 'operator approved deterministic local smoke',
+      },
+    ]);
+    expect(result).toMatchObject({
+      isError: false,
+      structuredContent: {
+        object: 'runtime_control',
+        action: 'resolve-local-action-request',
+        runId: 'run_tooling_1',
+        ok: true,
+        result: {
+          kind: 'local-action-control',
+          status: 'resolved',
+          resolved: true,
+        },
+      },
+    });
+  });
+
+  it('reports unsuccessful service-host controls as MCP tool errors with structured readback', async () => {
+    const calls: ExecutionServiceHostOperatorControlInput[] = [];
+    const handler = createRuntimeControlToolHandler({
+      serviceHost: {
+        async controlOperatorAction(input) {
+          calls.push(input);
+          return {
+            kind: 'run-control',
+            action: 'drain-run',
+            runId: 'run_not_ready',
+            status: 'skipped',
+            drained: false,
+            reason: 'run is not runnable',
+            skipReason: 'no-runnable-step',
+          } satisfies ExecutionServiceHostOperatorControlResult;
+        },
+      },
+    });
+
+    const result = await handler({
+      action: 'drain-run',
+      runId: 'run_not_ready',
+    });
+
+    expect(calls).toEqual([
+      {
+        kind: 'run-control',
+        control: {
+          action: 'drain-run',
+          runId: 'run_not_ready',
+        },
+      },
+    ]);
+    expect(result).toMatchObject({
+      isError: true,
+      structuredContent: {
+        object: 'runtime_control',
+        action: 'drain-run',
+        runId: 'run_not_ready',
+        ok: false,
+        result: {
+          kind: 'run-control',
+          status: 'skipped',
+          reason: 'run is not runnable',
+        },
+      },
+    });
+  });
+
+  it('requires request id and resolution for local-action request resolution', async () => {
+    const handler = createRuntimeControlToolHandler({
+      serviceHost: {
+        async controlOperatorAction() {
+          throw new Error('controlOperatorAction should not be called');
+        },
+      },
+    });
+
+    await expect(
+      handler({
+        action: 'resolve-local-action-request',
+        runId: 'run_tooling_1',
+      }),
+    ).rejects.toThrow('runtime_control resolve-local-action-request requires requestId.');
+  });
+});
