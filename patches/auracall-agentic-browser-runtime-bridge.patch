+        key: 'managed-profile:/tmp/managed/default/chatgpt::service:chatgpt',
+        kind: 'doctor',
+        operationClass: 'exclusive-probe',
+        managedProfileDir: '/tmp/managed/default/chatgpt',
+        serviceTarget: 'chatgpt',
