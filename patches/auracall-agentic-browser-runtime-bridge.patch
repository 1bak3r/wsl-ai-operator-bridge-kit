+#!/usr/bin/env tsx
+import os from 'node:os';
+import path from 'node:path';
+import { Client } from '@modelcontextprotocol/sdk/client/index.js';
+import { StdioClientTransport } from '@modelcontextprotocol/sdk/client/stdio.js';
+
+type BrowserReadinessMode = 'local' | 'live';
+type BrowserReadinessTarget = 'chatgpt' | 'grok' | 'gemini';
+
+interface Options {
+  failIfNotReady: boolean;
+  mcpBin: string;
+  mode: BrowserReadinessMode;
+  pruneBrowserState: boolean;
+  target: BrowserReadinessTarget;
+}
+
+function expandHome(input: string): string {
+  if (input === '~') return os.homedir();
+  if (input.startsWith('~/')) return path.join(os.homedir(), input.slice(2));
+  return input;
+}
+
+function resolveMcpCommand(input: string): string {
+  const expanded = expandHome(input);
+  if (path.isAbsolute(expanded)) return expanded;
+  return /[\\/]/.test(expanded) ? path.resolve(process.cwd(), expanded) : expanded;
+}
+
+function parseArgs(argv: string[]): Options {
+  const options: Options = {
+    failIfNotReady: false,
+    mcpBin: path.join(os.homedir(), '.local', 'bin', 'auracall-mcp'),
+    mode: 'local',
+    pruneBrowserState: false,
+    target: 'chatgpt',
+  };
+  for (let index = 0; index < argv.length; index += 1) {
+    const arg = argv[index];
+    if (arg === '--') continue;
+    if (arg === '--mcp-bin') {
+      const value = argv[index + 1];
+      if (!value) throw new Error('--mcp-bin requires a path.');
+      options.mcpBin = resolveMcpCommand(value);
+      index += 1;
+      continue;
+    }
+    if (arg === '--target') {
+      const value = argv[index + 1];
+      if (!value) throw new Error('--target requires chatgpt, grok, or gemini.');
+      options.target = parseTarget(value);
+      index += 1;
+      continue;
+    }
+    if (arg === '--mode') {
+      const value = argv[index + 1];
+      if (!value) throw new Error('--mode requires local or live.');
+      options.mode = parseMode(value);
+      index += 1;
+      continue;
+    }
+    if (arg === '--prune-browser-state') {
+      options.pruneBrowserState = true;
+      continue;
+    }
+    if (arg === '--fail-if-not-ready') {
+      options.failIfNotReady = true;
+      continue;
+    }
+    if (arg === '--help' || arg === '-h') {
+      printHelp();
+      process.exit(0);
+    }
+    throw new Error(`Unknown option: ${arg}`);
+  }
+  return options;
+}
+
+function parseTarget(value: string): BrowserReadinessTarget {
+  if (value === 'chatgpt' || value === 'grok' || value === 'gemini') return value;
+  throw new Error('--target must be chatgpt, grok, or gemini.');
+}
+
+function parseMode(value: string): BrowserReadinessMode {
+  if (value === 'local' || value === 'live') return value;
+  throw new Error('--mode must be local or live.');
+}
+
+function printHelp(): void {
+  console.log(`Smoke browser_readiness through one MCP stdio process.
+
+Usage:
+  pnpm tsx scripts/smoke-mcp-browser-readiness.ts [options]
+
+Options:
+  --mcp-bin <path>        AuraCall MCP binary. Default: ~/.local/bin/auracall-mcp
+  --target <provider>     chatgpt, grok, or gemini. Default: chatgpt
+  --mode <local|live>     local avoids provider page probes; live is read-only against an existing browser
+  --prune-browser-state   Prune dead browser-state entries before reporting
+  --fail-if-not-ready     Make the MCP tool call fail when readiness.ok is false
+  -h, --help              Show this help
+`);
+}
+
+async function callInstalledMcp(options: Options): Promise<{
+  agentAction: string;
+  agentCanDriveBrowser: boolean;
+  agentCommand: string | null;
+  ok: boolean;
+  recommendedAction: string | null;
+  requiresHuman: boolean;
+  severity: string;
+  state: string;
+  target: string;
+}> {
+  const client = new Client({ name: 'auracall-browser-readiness-mcp-smoke', version: '0.0.0' });
+  let stderr = '';
+  const transport = new StdioClientTransport({
+    command: options.mcpBin,
+    cwd: process.cwd(),
+    env: {
+      ...process.env,
+      AURACALL_DISABLE_KEYTAR: '1',
+    },
+    stderr: 'pipe',
+  });
+  transport.stderr?.on('data', (chunk) => {
+    stderr += String(chunk);
+  });
+
+  try {
+    await client.connect(transport);
+    const { tools } = await client.listTools({}, { timeout: 10_000 });
+    if (!tools.some((tool) => tool.name === 'browser_readiness')) {
+      throw new Error('Installed MCP server did not expose browser_readiness.');
+    }
+    const result = await client.callTool(
+      {
+        name: 'browser_readiness',
+        arguments: {
+          target: options.target,
+          mode: options.mode,
+          pruneBrowserState: options.pruneBrowserState,
+          failIfNotReady: options.failIfNotReady,
+        },
+      },
+      undefined,
+      { timeout: 30_000 },
+    );
+    if (result.isError && !options.failIfNotReady) {
+      throw new Error('browser_readiness returned an MCP error unexpectedly.');
+    }
+    const structured = asRecord(result.structuredContent, 'browser_readiness structuredContent');
+    if (structured.object !== 'browser_readiness') {
+      throw new Error(`Unexpected object: ${String(structured.object)}`);
+    }
+    const agentDecision = asRecord(structured.agentDecision, 'browser_readiness agentDecision');
+    return {
+      agentAction: expectString(agentDecision.action, 'agentDecision.action'),
+      agentCanDriveBrowser: expectBoolean(agentDecision.canDriveBrowser, 'agentDecision.canDriveBrowser'),
+      agentCommand: expectNullableString(agentDecision.command, 'agentDecision.command'),
+      ok: expectBoolean(structured.ok, 'ok'),
+      recommendedAction: expectNullableString(structured.recommendedAction, 'recommendedAction'),
+      requiresHuman: expectBoolean(structured.requiresHuman, 'requiresHuman'),
+      severity: expectString(structured.severity, 'severity'),
+      state: expectString(structured.state, 'state'),
+      target: expectString(structured.target, 'target'),
+    };
+  } finally {
+    await client.close().catch(() => {});
+    transport.close?.();
+    if (stderr.trim().length > 0 && process.env.AURACALL_SMOKE_DEBUG_STDERR === '1') {
+      console.error(stderr.trim());
+    }
+  }
+}
+
+function asRecord(value: unknown, label: string): Record<string, unknown> {
+  if (!value || typeof value !== 'object' || Array.isArray(value)) {
+    throw new Error(`${label}: expected object, got ${String(value)}.`);
+  }
+  return value as Record<string, unknown>;
+}
+
+function expectBoolean(value: unknown, label: string): boolean {
+  if (typeof value !== 'boolean') {
+    throw new Error(`${label}: expected boolean, got ${String(value)}.`);
+  }
+  return value;
+}
+
+function expectString(value: unknown, label: string): string {
+  if (typeof value !== 'string') {
+    throw new Error(`${label}: expected string, got ${String(value)}.`);
+  }
+  return value;
+}
+
+function expectNullableString(value: unknown, label: string): string | null {
+  if (value === null || typeof value === 'string') return value;
+  throw new Error(`${label}: expected string or null, got ${String(value)}.`);
+}
+
+async function main(): Promise<void> {
+  const options = parseArgs(process.argv.slice(2));
+  const readiness = await callInstalledMcp(options);
+  console.log(
+    `browser_readiness target=${readiness.target} mode=${options.mode} ok=${readiness.ok} state=${readiness.state} severity=${readiness.severity} requiresHuman=${readiness.requiresHuman} agentAction=${readiness.agentAction} canDriveBrowser=${readiness.agentCanDriveBrowser}`,
+  );
+  if (readiness.agentCommand) {
+    console.log(`agentCommand=${readiness.agentCommand}`);
+  }
+  if (readiness.recommendedAction) {
+    console.log(`recommendedAction=${readiness.recommendedAction}`);
+  }
+}
+
+main().catch((error) => {
+  console.error(error instanceof Error ? error.message : String(error));
+  process.exit(1);
+});
