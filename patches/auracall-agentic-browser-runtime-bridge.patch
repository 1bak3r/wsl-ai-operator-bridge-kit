+type BrowserManualClearWaitResult = {
+  ok: boolean;
+  summary: string;
+  lastBlockingState: RuntimeBlockingStateLike | null;
+};
+
+async function waitForBrowserManualClearance(input: {
+  target: 'chatgpt' | 'gemini' | 'grok';
+  userConfig: ResolvedUserConfig;
+  waitMs: number;
+  pruneBrowserState?: boolean;
+  jsonMode?: boolean;
+  initialBlockingState?: RuntimeBlockingStateLike | null;
+  inspectBrowserDoctorState: typeof import('../src/browser/profileDoctor.js').inspectBrowserDoctorState;
+  collectBrowserFeatureRuntime: typeof import('../src/browser/profileDoctor.js').collectBrowserFeatureRuntime;
+}): Promise<BrowserManualClearWaitResult> {
+  if (input.waitMs <= 0) {
+    return {
+      ok: true,
+      summary: 'Manual-clear wait disabled.',
+      lastBlockingState: input.initialBlockingState ?? null,
+    };
+  }
+
+  const deadline = Date.now() + input.waitMs;
+  let lastBlockingState = input.initialBlockingState ?? null;
+  let lastSummary = lastBlockingState?.summary?.trim() || `Waiting for ${input.target} browser page to clear.`;
+
+  if (!input.jsonMode) {
+    console.log('');
+    console.log(
+      chalk.yellow(
+        `${lastSummary} Waiting up to ${Math.round(input.waitMs / 1000)}s for manual clearance in the managed browser.`,
+      ),
+    );
+    console.log(
+      chalk.dim(
+        'AuraCall will observe readiness and resume after the page clears; it will not solve CAPTCHA or anti-bot challenges.',
+      ),
+    );
+  }
+
+  for (;;) {
+    const waitLocalReport = await input.inspectBrowserDoctorState(input.userConfig, {
+      target: input.target,
+      pruneDeadRegistryEntries: Boolean(input.pruneBrowserState),
+    });
+    if (!waitLocalReport.managedRegistryEntry?.alive) {
+      lastBlockingState = null;
+      lastSummary = `No live managed ${input.target} browser instance is available for manual clearance.`;
+    } else {
+      const waitRuntime = await input.collectBrowserFeatureRuntime(input.target, waitLocalReport);
+      const waitBlockingState = getRuntimeBlockingState(waitRuntime.browserTools);
+      if (!waitBlockingState?.requiresHuman) {
+        return {
+          ok: true,
+          summary: `Managed ${input.target} browser page is no longer on a human-clear blocking surface.`,
+          lastBlockingState,
+        };
+      }
+      lastBlockingState = waitBlockingState;
+      lastSummary = waitBlockingState.summary?.trim() || 'Blocking page still requires manual clearance.';
+    }
+
+    if (Date.now() >= deadline) {
+      return {
+        ok: false,
+        summary: `${lastSummary} Timed out after ${Math.round(input.waitMs / 1000)}s waiting for manual clearance.`,
+        lastBlockingState,
+      };
+    }
+
+    const remainingMs = Math.max(0, deadline - Date.now());
+    await sleep(Math.min(5_000, remainingMs));
+  }
+}
