new file mode 100644
index 00000000..9439f82a
--- /dev/null
+++ b/src/mcp/tools/browserReadiness.ts
@@ -0,0 +1,289 @@
+import type { McpServer } from '@modelcontextprotocol/sdk/server/mcp.js';
+import { z } from 'zod';
+import type { ResolvedUserConfig } from '../../config.js';
+import {
+  collectBrowserFeatureRuntime,
+  createAuracallBrowserDoctorContract,
+  inspectBrowserDoctorFeatures,
+  inspectBrowserDoctorIdentity,
+  inspectBrowserDoctorState,
+  reconcileBrowserDoctorIdentities,
+  withBrowserProbeOperation,
+  type AuracallBrowserDoctorContract,
+  type BrowserDoctorFeatureReport,
+  type BrowserDoctorIdentityReconciliation,
+  type BrowserDoctorIdentityReport,
+  type BrowserDoctorReport,
+  type BrowserDoctorTarget,
+} from '../../browser/profileDoctor.js';
+
+const browserReadinessTargetNames = ['chatgpt', 'grok', 'gemini'] as const;
+const browserReadinessModeNames = ['local', 'live'] as const;
+const browserReadinessSeverityNames = ['ready', 'info', 'warning', 'blocked'] as const;
+const browserReadinessAgentActionNames = [
+  'proceed',
+  'setup-browser',
+  'prune-browser-state',
+  'launch-login',
+  'wait-for-human',
+  'configure-identity',
+  'update-selectors',
+  'inspect-diagnostics',
+] as const;
+
+const browserReadinessInputShape = {
+  target: z.enum(browserReadinessTargetNames).optional(),
+  mode: z.enum(browserReadinessModeNames).optional(),
+  pruneBrowserState: z.boolean().optional(),
+  failIfNotReady: z.boolean().optional(),
+} satisfies z.ZodRawShape;
+
+const browserReadinessOutputShape = {
+  object: z.literal('browser_readiness'),
+  target: z.enum(browserReadinessTargetNames),
+  mode: z.enum(browserReadinessModeNames),
+  ok: z.boolean(),
+  state: z.string(),
+  severity: z.enum(browserReadinessSeverityNames),
+  requiresHuman: z.boolean(),
+  recommendedAction: z.string().nullable(),
+  agentDecision: z.object({
+    action: z.enum(browserReadinessAgentActionNames),
+    canDriveBrowser: z.boolean(),
+    command: z.string().nullable(),
+    reason: z.string(),
+  }),
+  doctor: z.unknown(),
+} satisfies z.ZodRawShape;
+
+export interface RegisterBrowserReadinessToolDeps {
+  resolvedUserConfig: ResolvedUserConfig;
+  inspectBrowserDoctorState?: typeof inspectBrowserDoctorState;
+  inspectBrowserDoctorIdentity?: typeof inspectBrowserDoctorIdentity;
+  inspectBrowserDoctorFeatures?: typeof inspectBrowserDoctorFeatures;
+  reconcileBrowserDoctorIdentities?: typeof reconcileBrowserDoctorIdentities;
+  collectBrowserFeatureRuntime?: typeof collectBrowserFeatureRuntime;
+  withBrowserProbeOperation?: typeof withBrowserProbeOperation;
+  createAuracallBrowserDoctorContract?: typeof createAuracallBrowserDoctorContract;
+}
+
+type BrowserReadinessInput = z.infer<z.ZodObject<typeof browserReadinessInputShape>>;
+type BrowserReadinessMode = (typeof browserReadinessModeNames)[number];
+type BrowserReadinessAgentAction = (typeof browserReadinessAgentActionNames)[number];
+
+interface BrowserReadinessAgentDecision {
+  action: BrowserReadinessAgentAction;
+  canDriveBrowser: boolean;
+  command: string | null;
+  reason: string;
+}
+
+export function registerBrowserReadinessTool(
+  server: McpServer,
+  deps: RegisterBrowserReadinessToolDeps,
+): void {
+  server.registerTool(
+    'browser_readiness',
+    {
+      title: 'Read Aura-Call browser readiness',
+      description:
+        'Return the versioned Aura-Call browser doctor/readiness contract for an MCP client. The default local mode does not launch or attach to provider pages; live mode performs read-only probes against an already registered managed browser.',
+      inputSchema: browserReadinessInputShape,
+      outputSchema: browserReadinessOutputShape,
+    },
+    createBrowserReadinessToolHandler(deps),
+  );
+}
+
+export function createBrowserReadinessToolHandler(
+  deps: RegisterBrowserReadinessToolDeps,
+) {
+  const inspectState = deps.inspectBrowserDoctorState ?? inspectBrowserDoctorState;
+  const inspectIdentity = deps.inspectBrowserDoctorIdentity ?? inspectBrowserDoctorIdentity;
+  const inspectFeatures = deps.inspectBrowserDoctorFeatures ?? inspectBrowserDoctorFeatures;
+  const reconcileIdentities = deps.reconcileBrowserDoctorIdentities ?? reconcileBrowserDoctorIdentities;
+  const collectRuntime = deps.collectBrowserFeatureRuntime ?? collectBrowserFeatureRuntime;
+  const runProbeOperation = deps.withBrowserProbeOperation ?? withBrowserProbeOperation;
+  const createDoctorContract = deps.createAuracallBrowserDoctorContract ?? createAuracallBrowserDoctorContract;
+
+  return async (rawInput: unknown) => {
+    const payload = z.object(browserReadinessInputShape).parse(rawInput);
+    const target = resolveBrowserReadinessTarget(payload, deps.resolvedUserConfig);
+    const mode: BrowserReadinessMode = payload.mode ?? 'local';
+    const localReport = await inspectState(deps.resolvedUserConfig, {
+      target,
+      pruneDeadRegistryEntries: Boolean(payload.pruneBrowserState),
+    });
+
+    let operation: AuracallBrowserDoctorContract['runtime']['operation'] = null;
+    let identityStatus: BrowserDoctorIdentityReport | null = null;
+    let identityReconciliation: BrowserDoctorIdentityReconciliation | null = null;
+    let featureStatus: BrowserDoctorFeatureReport | null = null;
+    let browserTools: AuracallBrowserDoctorContract['runtime']['browserTools'] = null;
+    let browserToolsError: string | null = null;
+    let selectorDiagnosisError: string | null = null;
+
+    if (mode === 'live') {
+      try {
+        await runProbeOperation(target, localReport, 'doctor', async (activeOperation) => {
+          operation = activeOperation;
+          identityStatus = await inspectIdentity(deps.resolvedUserConfig, {
+            target,
+            localReport,
+          });
+          identityReconciliation = reconcileIdentities(
+            deps.resolvedUserConfig,
+            target,
+            localReport,
+            identityStatus,
+          );
+          if (identityStatus.error) {
+            browserToolsError = identityStatus.error;
+            selectorDiagnosisError = identityStatus.error;
+            return;
+          }
+          const runtime = await collectRuntime(target, localReport);
+          browserTools = runtime.browserTools;
+          browserToolsError = runtime.browserToolsError;
+          featureStatus = await inspectFeatures(deps.resolvedUserConfig, {
+            target,
+            localReport,
+            browserTools,
+          });
+        });
+      } catch (error) {
+        const message = error instanceof Error ? error.message : String(error);
+        browserToolsError = message;
+        selectorDiagnosisError = message;
+      }
+    }
+
+    identityReconciliation ??= reconcileIdentities(
+      deps.resolvedUserConfig,
+      target,
+      localReport,
+      identityStatus,
+    );
+    const doctor = createDoctorContract({
+      target,
+      localReport,
+      identityStatus,
+      identityReconciliation,
+      featureStatus,
+      operation,
+      browserTools,
+      browserToolsError,
+      selectorDiagnosis: null,
+      selectorDiagnosisError,
+    });
+    const readiness = doctor.readiness;
+    const agentDecision = createBrowserReadinessAgentDecision(target, doctor);
+    const structuredContent = {
+      object: 'browser_readiness' as const,
+      target,
+      mode,
+      ok: readiness.ok,
+      state: readiness.state,
+      severity: readiness.severity,
+      requiresHuman: readiness.requiresHuman,
+      recommendedAction: readiness.recommendedAction,
+      agentDecision,
+      doctor,
+    };
+
+    return {
+      isError: Boolean(payload.failIfNotReady && !readiness.ok),
+      content: [
+        {
+          type: 'text' as const,
+          text:
+            `Aura-Call browser readiness for ${target}: ${readiness.state}` +
+            ` (${readiness.severity}); action=${agentDecision.action}; ${readiness.summary}`,
+        },
+      ],
+      structuredContent,
+    };
+  };
+}
+
+function resolveBrowserReadinessTarget(
+  input: BrowserReadinessInput,
+  userConfig: ResolvedUserConfig,
+): BrowserDoctorTarget {
+  const target = input.target ?? userConfig.browser?.target ?? 'chatgpt';
+  if (target !== 'chatgpt' && target !== 'grok' && target !== 'gemini') {
+    throw new Error(`Invalid browser readiness target "${String(target)}".`);
+  }
+  return target;
+}
+
+export function createBrowserReadinessAgentDecision(
+  target: BrowserDoctorTarget,
+  doctor: AuracallBrowserDoctorContract,
+): BrowserReadinessAgentDecision {
+  const readiness = doctor.readiness;
+  const state = readiness.state;
+  const reason = readiness.summary;
+  if (readiness.ok) {
+    return {
+      action: 'proceed',
+      canDriveBrowser: true,
+      command: null,
+      reason,
+    };
+  }
+  if (state === 'managed-profile-missing') {
+    return {
+      action: 'setup-browser',
+      canDriveBrowser: false,
+      command: `auracall setup --target ${target}`,
+      reason,
+    };
+  }
+  if (state === 'no-live-managed-browser') {
+    if (doctor.localReport.staleRegistryEntries.length > 0) {
+      return {
+        action: 'prune-browser-state',
+        canDriveBrowser: false,
+        command: `auracall doctor --target ${target} --local-only --prune-browser-state`,
+        reason,
+      };
+    }
+    return {
+      action: 'launch-login',
+      canDriveBrowser: false,
+      command: `auracall login --target ${target} --wait-for-manual-clear auto`,
+      reason,
+    };
+  }
+  if (readiness.requiresHuman || state === 'manual-clear-required' || state === 'login-required') {
+    return {
+      action: 'wait-for-human',
+      canDriveBrowser: false,
+      command: `auracall login --target ${target} --wait-for-manual-clear auto`,
+      reason,
+    };
+  }
+  if (state === 'identity-unconfigured') {
+    return {
+      action: 'configure-identity',
+      canDriveBrowser: false,
+      command: null,
+      reason,
+    };
+  }
+  if (state === 'selector-drift') {
+    return {
+      action: 'update-selectors',
+      canDriveBrowser: false,
+      command: `auracall doctor --target ${target} --save-snapshot`,
+      reason,
+    };
+  }
+  return {
+    action: 'inspect-diagnostics',
+    canDriveBrowser: false,
+    command: `auracall doctor --target ${target} --json --save-snapshot`,
+    reason,
+  };
+}
