+}
+
+async function readStoredSessionAsResponse(
+  id: string,
+  sessions: Pick<SessionStore, 'readSession' | 'readLog' | 'readRequest'>,
+) {
+  const metadata = await sessions.readSession(id);
+  if (!metadata) {
+    return null;
+  }
+  const [log, request] = await Promise.all([
+    sessions.readLog(id),
+    sessions.readRequest(id),
+  ]);
