+import { detectChromiumBrowserFamily } from './platformPaths.js';
+
+export type DevToolsVersionPayload = {
+  Browser?: unknown;
+  'User-Agent'?: unknown;
+};
+
+export function isMicrosoftEdgePath(value: string | null | undefined): boolean {
+  return detectChromiumBrowserFamily(value) === 'edge';
+}
+
+export function assertChromeLaunchPath(value: string | null | undefined): void {
+  if (!isMicrosoftEdgePath(value)) {
+    return;
+  }
+  throw new Error(
+    'AuraCall browser remote debugging must use Google Chrome, not Microsoft Edge. ' +
+      `Configure browser.chromePath/CHROME_PATH to a chrome.exe or google-chrome path; got ${value}.`,
+  );
+}
+
+export function isChromeCompatibleDevToolsVersion(version: DevToolsVersionPayload): boolean {
+  const product = String(version.Browser ?? '');
+  const userAgent = String(version['User-Agent'] ?? '');
+  const productName = product.split('/')[0]?.trim().toLowerCase();
+  if (isMicrosoftEdgeDevToolsVersion(product, userAgent)) {
+    return false;
+  }
+  return productName === 'chrome' || productName === 'headlesschrome' || productName === 'chromium';
+}
+
+export function describeDevToolsBrowser(version: DevToolsVersionPayload): string {
+  const product = String(version.Browser ?? '').trim();
+  const userAgent = String(version['User-Agent'] ?? '').trim();
+  if (product && userAgent) {
+    return `${product} (${userAgent})`;
+  }
+  return product || userAgent || 'unknown browser';
+}
+
+function isMicrosoftEdgeDevToolsVersion(product: string, userAgent: string): boolean {
+  const combined = `${product} ${userAgent}`;
+  return /\bmicrosoft edge\b/i.test(combined) || /\bEdg(?:e|A|iOS)?\//i.test(combined);
+}
