+    browserProfileMismatchIsInformational: false,
+    summary: 'Provider app session was not verified for expected expected@example.test.',
+    ...overrides,
+  };
+}
+
+describe('mcp browser_readiness tool', () => {
+  it('returns the local browser doctor readiness contract without probing a live page by default', async () => {
+    const localReport = createLocalReport();
+    const inspectBrowserDoctorState = vi.fn(async () => localReport);
+    const inspectBrowserDoctorIdentity = vi.fn();
+    const collectBrowserFeatureRuntime = vi.fn();
+    const reconcileBrowserDoctorIdentities = vi.fn(() => createIdentityReconciliation());
+    const handler = createBrowserReadinessToolHandler({
+      resolvedUserConfig: {
+        browser: {
+          target: 'chatgpt',
+        },
+      } as never,
+      inspectBrowserDoctorState,
+      inspectBrowserDoctorIdentity: inspectBrowserDoctorIdentity as never,
+      collectBrowserFeatureRuntime: collectBrowserFeatureRuntime as never,
+      reconcileBrowserDoctorIdentities: reconcileBrowserDoctorIdentities as never,
+      createAuracallBrowserDoctorContract,
+    });
+
+    const result = await handler({});
+
+    expect(inspectBrowserDoctorState).toHaveBeenCalledWith(
+      expect.objectContaining({
+        browser: {
+          target: 'chatgpt',
+        },
+      }),
